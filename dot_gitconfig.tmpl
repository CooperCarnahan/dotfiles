[core]
  editor = nvim
  excludesfile = ~/.gitignore_global
  pager = delta
  # perf: fsmonitor daemon + untracked cache make `git status` near-instant
  # on large repos; no-ops on small ones.
  fsmonitor = true
  untrackedCache = true

{{- if eq .chezmoi.os "windows" }}
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- else if eq .chezmoi.os "linux" }}
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
  sshCommand = ssh.exe
{{- end }}
{{- end }}

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true

[merge]
  # zdiff3 adds the common-ancestor block to conflict markers
  conflictstyle = zdiff3

[diff]
  colorMoved = default
  algorithm = histogram

[fetch]
  prune = true

[push]
  autoSetupRemote = true

[pull]
  rebase = true

[rebase]
  autoStash = true
  autoSquash = true
  # rebasing a branch moves any stacked-branch refs that point into it
  updateRefs = true

[column]
  ui = auto

[alias]
  brt = "!git for-each-ref refs/heads --color=always --sort -committerdate --format='%(HEAD)%(color:reset);%(color:yellow)%(refname:short)%(color:reset);%(contents:subject);%(color:green)(%(committerdate:relative))%(color:blue);<%(authorname)>' | column -t -s ';'"
  fpush = push --force-with-lease

  # Difftastic aliases, so `git dlog` is `git log` with difftastic and so on.
  dlog = -c diff.external=difft log --ext-diff
  dshow = -c diff.external=difft show --ext-diff
  ddiff = -c diff.external=difft diff
  # `git log` with patches shown with difftastic.
  dl = -c diff.external=difft log -p --ext-diff

  # Show the most recent commit with difftastic.
  ds = -c diff.external=difft show --ext-diff

  # `git diff` with difftastic.
  dft = -c diff.external=difft diff

{{- if not .work }}
# 1password signing stuff
[gpg]
  format = ssh

[gpg "ssh"]
{{- if eq .chezmoi.os "windows" }}
  program = {{ lookPath "op-ssh-sign.exe" | quote }}
{{- else if eq .chezmoi.os "darwin" }}
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[credential]
  # op-ssh-sign above only covers signing; HTTPS auth needs a helper too
  helper = osxkeychain
{{- else if eq .chezmoi.os "linux" }}
  {{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
  program = {{ lookPath "op-ssh-sign.exe" | quote }}

[credential]
  helper = {{ lookPath "git-credential-manager.exe" | quote }}
  useHttpPath = true
  {{- else }}
  program = /opt/1Password/op-ssh-sign

[credential]
  helper = manager
  credentialStore = secretservice
  useHttpPath = true
  {{- end }}
{{- end }}

[commit]
  gpgsign = true

[user]
  email = coopcarn@gmail.com
  name = CooperCarnahan

  # 1password public key for github signing key
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIIeClNytAT5eG6YM0L/giuA9pw9kRCgEmxEcz1uoa5yy
{{- end }}

[init]
  defaultBranch = main

[rerere]
  enabled = true
  autoUpdate = true

[branch]
  sort = -committerdate

[tag]
  sort = -version:refname

# Per-machine private profiles. Git silently ignores missing include
# files, so these are no-ops on machines where the file isn't present.
# Maintained out-of-band (not chezmoi-managed).
#   local - machine-local overrides (e.g. credential helper on a box
#           with no Secret Service keyring). Loaded last so it wins.
[include]
  path = ~/.config/git/local
