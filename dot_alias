#!/bin/sh
# POSIX-shell aliases (bash/zsh). Nushell has its own copies in config.nu —
# keep the two in sync when touching shared names (v, zj, fdi, lg, gsur, ...).

###########################
#          ls / eza       #
###########################
if command -v eza > /dev/null 2>&1; then
    alias ls='eza -s extension --icons --no-time --no-user --no-permissions --group-directories-first'
    alias ll='eza -l -s extension --icons'
    alias lt='eza --tree'
elif [ "$(uname -s)" = "Darwin" ]; then
    alias ls='ls -G'
    alias ll='ls -alG'
else
    alias ls='ls --color=auto --group-directories-first'
    alias ll='ls -al --color=auto'
fi
alias la='ls -a'
alias lla='ls -la'

###########################
#        Misc.            #
###########################
alias grep='grep --color=auto'
alias python=python3

alias v='nvim'
alias zj='zellij'
alias fdi='fd -IH'

# Installing bat from apt uses 'batcat' to avoid naming clash
if command -v batcat > /dev/null 2>&1; then
    alias batcat='bat'
fi

if command -v bat > /dev/null 2>&1; then
    alias cat='bat'
fi

# yazi with cwd follow: exit yazi inside a directory, land there in the shell
function yz() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

###########################
# Directory navigation    #
###########################
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."
alias 1='cd -'
alias 2='cd -2'
alias 3='cd -3'
alias 4='cd -4'
alias 5='cd -5'
alias 6='cd -6'
alias 7='cd -7'
alias 8='cd -8'
alias 9='cd -9'

###########################
# Dotfile-related Alias'  #
###########################
alias src='source ~/.zshrc'
alias ea='nvim ~/.alias'

###########################
#       TMUX Alias'       #
###########################
alias tma='tmux attach-session -t'
alias tmuxa='tmux attach-session -t'
alias tmn='tmux new-session -s'
alias tmuxn='tmux new-session -s'

###########################
#      Git Alias'         #
###########################
# forgit (ga, glo, gd, grb, ...) defines its own aliases when the zsh plugin
# loads — no need to duplicate them here.
alias lg='lazygit'
alias gsur='git submodule update --init --recursive -j 12'
alias gbsc='git branch --show-current'
alias grh='git reset --hard'
alias grho='git reset --hard origin/$(git branch --show-current)'
alias gcf='git commit --fixup'

###########################
#      Local Alias'       #
###########################
if [ -f $HOME/.alias.local ]; then
    source $HOME/.alias.local
fi
