{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Continue'
$ProgressPreference = 'SilentlyContinue'

function Write-Step {
    param([string]$Message)
    Write-Host "`n==> $Message" -ForegroundColor Cyan
}

function Refresh-SessionEnvironment {
    Write-Host "Refreshing environment variables from registry..." -ForegroundColor Gray

    $machinePath = [System.Environment]::GetEnvironmentVariable("Path", "Machine")
    $userPath = [System.Environment]::GetEnvironmentVariable("Path", "User")
    $env:Path = "$machinePath;$userPath"
}

{{- if .work }}
Write-Host "`n[MODE: WORK]" -ForegroundColor Magenta
{{- else }}
Write-Host "`n[MODE: PERSONAL]" -ForegroundColor Magenta
{{- end }}

# 1. WinGet Package Installs
Write-Step "Installing packages via WinGet"

$packages = @(
    # Microsoft.Git, not Git.Git: the machines run the Scalar/VFS-aware fork,
    # and installing vanilla Git.Git over it is a flavor switch the installer
    # refuses under --silent (exit 1). The fork is a superset of Git for
    # Windows and upgrades in-flavor via `winget upgrade`.
    "Microsoft.Git"  # scoop bucket adds below need git; Linux bootstrap installs it too
    "Microsoft.VisualStudioCode"
    "Microsoft.PowerToys"
)

{{- if not .work }}
# Personal-only winget packages
$packages += @(
    "NordSecurity.NordVPN"
    "AgileBits.1Password"
    "AgileBits.1Password.CLI"
    "Anthropic.Claude"
    "Zen-Team.Zen-Browser"
)
{{- end }}

if (Get-Command winget -ErrorAction SilentlyContinue) {
    foreach ($pkg in $packages) {
        Write-Host "Installing $pkg..." -ForegroundColor Gray
        # --no-upgrade keeps this install loop fast and present-only; the
        # dedicated upgrade phase at the tail of this script runs
        # `winget upgrade --all` once presence is ensured.
        winget install --id $pkg --silent --no-upgrade --accept-source-agreements --accept-package-agreements
    }
} else {
    Write-Warning "WinGet not found. Skipping winget package installs."
}

Refresh-SessionEnvironment

# 2. Scoop Setup
Write-Step "Checking Scoop installation"
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "Installing Scoop..." -ForegroundColor Gray
    Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression
    $env:Path += ";$env:USERPROFILE\scoop\shims"
}

if (-not (Get-Command git -ErrorAction SilentlyContinue)) {
    Write-Warning "Git not found. Scoop bucket operations may fail."
}

Write-Step "Adding Scoop buckets"
$ScoopBuckets = @('extras', 'nerd-fonts')
foreach ($Bucket in $ScoopBuckets) {
    scoop bucket add $Bucket 2>$null
}

Write-Step "Installing Scoop packages"
$ScoopPackages = @(
    # main bucket
    'aria2'
    'gzip'
    'unzip'
    'mise'
    'nanazip'
    # extras bucket
    'extras/glazewm'
    'extras/universal-ctags'
    'extras/clipboard'
    # nerd-fonts bucket
    'nerd-fonts/CascadiaCode-NF'
    'nerd-fonts/Maple-Mono-NF'
)

foreach ($Package in $ScoopPackages) {
    Write-Host "Installing $Package..." -ForegroundColor Gray
    scoop install $Package
}

# 3. mise-managed tools. Must happen in this before_ script: chezmoi's
# [interpreters.nu] modify scripts need `nu` (mise-provided on every OS) before
# file targets are applied — same ordering the arch/darwin bootstraps use.
Write-Step "Installing mise-managed tools"
Refresh-SessionEnvironment
$env:Path = "$env:USERPROFILE\scoop\shims;$env:Path"
if (Get-Command mise -ErrorAction SilentlyContinue) {
    mise install
} else {
    # Hard-fail rather than warn: the file targets in this same apply include
    # [interpreters.nu] modify-scripts that need `nu` (mise-provided). Proceeding
    # would half-apply them against a missing interpreter. Stop so the user can
    # re-run once scoop's mise shim is on PATH.
    throw "mise not found on PATH after scoop install. Open a new shell (or run 'mise install' manually), then re-run 'chezmoi apply'."
}

# 4. Upgrade everything, then a system summary — so a `chezmoi update` pass
# (pull + apply that re-runs this script) completes with a full refresh,
# mirroring the Arch bootstrap's `mise upgrade` + trailing fastfetch.
Write-Step "Upgrading installed packages"

# Plain `mise upgrade` (no --bump): upgrades the installed tools to satisfy the
# chezmoi-managed `latest` pins without rewriting config.toml. mise itself is
# scoop-managed on Windows, so `scoop update` below bumps it — no `mise
# self-update`, which would fight scoop's copy.
mise upgrade

if (Get-Command winget -ErrorAction SilentlyContinue) {
    winget upgrade --all --silent --accept-source-agreements --accept-package-agreements
}

if (Get-Command scoop -ErrorAction SilentlyContinue) {
    scoop update *
}

Write-Host "`nWindows package setup completed!" -ForegroundColor Green

# fastfetch is mise-provided; guard so a missing binary can't fail the pass
# (matches the darwin script's guarded trailing fastfetch).
if (Get-Command fastfetch -ErrorAction SilentlyContinue) {
    fastfetch
}
{{- end }}
