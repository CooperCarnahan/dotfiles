{{- if eq .chezmoi.os "linux" -}}
{{- /* Debian family: id is debian/ubuntu/raspbian/..., or id_like contains debian. */ -}}
{{- $deb := false -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $deb = eq .chezmoi.osRelease.id "debian" -}}
{{- end -}}
{{- if and (not $deb) (hasKey .chezmoi.osRelease "idLike") -}}
{{-   $deb = contains "debian" .chezmoi.osRelease.idLike -}}
{{- end -}}
{{- if $deb -}}
#!/usr/bin/env bash
# System packages for Debian/Ubuntu-family machines.
#
# Philosophy: development *tools* (chezmoi, nu, jq, ripgrep, fd, uv, node, ...)
# are provisioned by mise from ~/.config/mise/config.toml — NOT apt. This script
# installs only what mise can't: the C build toolchain and system libraries that
# some mise tools compile against, plus base CLI utilities. mise itself is
# bootstrapped here; the full tool set materializes in the AFTER phase
# (run_onchange_after_install_mise_toolchain) once the file phase has applied
# the real mise config — running `mise install` here on a fresh box is a no-op
# because ~/.config/mise/config.toml doesn't exist yet.
#
# config-version: 1
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

# System packages only — no PPAs, no desktop stack, no mise-managed tools.
packages=(
    build-essential
    pkg-config
    libssl-dev
    ca-certificates
    curl
    git
    unzip
)

echo "--- apt: updating package lists ---"
sudo apt-get update -y

echo "--- apt: installing system packages ---"
sudo apt-get install -y --no-install-recommends "${packages[@]}"

echo "--- Checking for mise installation ---"
if ! command -v mise >/dev/null 2>&1; then
    echo "mise not found. Installing mise..."
    curl https://mise.run | sh
    # Add mise to PATH for the current session so `mise install` below resolves.
    export PATH="$HOME/.local/bin:$PATH"
fi

echo "--- Ensuring nushell for the chezmoi file phase ---"
# modify_*.nu scripts and [interpreters.nu] need `nu` DURING the file phase,
# before the managed mise config lands. `mise use -g` writes a stub global
# config (immediately overwritten by the file phase) and installs nushell; the
# ~/.local/bin symlink makes `nu` resolvable wherever chezmoi itself is.
if ! command -v nu >/dev/null 2>&1; then
    mise use --global aqua:nushell/nushell@latest
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(mise which nu)" "$HOME/.local/bin/nu"
fi

echo "--- system packages installed ---"
{{- end -}}
{{- end -}}
