{
  "$schema": "https://www.schemastore.org/claude-code-keybindings.json",
  "$docs": "https://code.claude.com/docs/en/keybindings",
  "bindings": [
    {
      "context": "Scroll",
      "bindings": {
        "ctrl+d": "scroll:halfPageDown",
        "ctrl+u": "scroll:halfPageUp",
        "ctrl+j": "scroll:lineDown",
        "ctrl+k": "scroll:lineUp"
      }
    }
  ]
}
