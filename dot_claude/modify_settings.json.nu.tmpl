#!/usr/bin/env nu
# chezmoi modify_ script for ~/.claude/settings.json
#
# The .nu extension is deliberate: [interpreters.nu] in chezmoi.toml runs this
# via `nu --stdin` on every OS (Windows can't exec a shebang), and chezmoi
# strips a matching interpreter extension from the target name —
# settings.json.nu -> settings.json. `--stdin` is what wires the live file
# into $in.
#
# Claude Code owns this file: it rewrites it in its own key order and appends
# runtime keys (notif flags, session-accreted permissions) during normal use.
# A plain whole-file template fights that and makes `chezmoi diff` a wall of
# reordering noise. Instead this script receives the LIVE file on stdin and
# merges in only the "stable" keys we want chezmoi to own. Nushell records
# preserve JSON key order, so Claude's key order and its runtime-mutated keys
# survive the merge and `chezmoi diff` stays quiet.
#
# Floats (never touched once present): permissions.*, defaultMode,
# agentPushNotifEnabled, inputNeededNotifEnabled, and any future keys Claude adds.
# `permissions` is only seeded on a fresh machine (when the file doesn't exist).

# Body lives in main: nu rejects `$in` at script top level ("can't evaluate
# block in IR mode"); with --stdin, main receives stdin as pipeline input.
def main [] {

# str trim: treat whitespace-only stdin (not just 0 bytes) as a missing file.
let raw = ($in | default "" | str trim)

let live = (if ($raw | is-empty) { "{}" } else { $raw }) | from json

# Canonical desired config. Edit values HERE to change what chezmoi enforces.
# DISABLE_AUTOUPDATER: mise owns the claude binary on every machine; the
# self-updater must stay off or it installs a parallel "native" copy under
# $HOME/.local/bin and warns on startup when PATH resolves to mise's copy
# instead (worst on Windows boxes where Cadence sets HOME=C:\SPB_Data).
let desired = r#'
{
  "editorMode": "vim",
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-hud@claude-hud": true,
    "context-mode@context-mode": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "GIT_AUTHOR_EMAIL": "noreply@anthropic.com",
    "GIT_AUTHOR_NAME": "Claude",
    "GIT_COMMITTER_EMAIL": "noreply@anthropic.com",
    "GIT_COMMITTER_NAME": "Claude",
    "GIT_CONFIG_PARAMETERS": "'commit.gpgsign=false' 'tag.gpgsign=false'"
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "repo": "jarrodwatts/claude-hud",
        "source": "github"
      }
    },
    "context-mode": {
      "source": {
        "repo": "mksglu/context-mode",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ lookPath "node" | replace "\\" "/" }} \"{{ .chezmoi.homeDir }}/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "mcp__plugin_context-mode_context-mode__ctx_purge"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": {{ if eq .chezmoi.os "windows" }}false{{ else }}true{{ end }},
    "filesystem": {
      "allowRead": [
        "~/.ssh/claude_signing",
        "~/.ssh/claude_signing.pub"
      ],
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/.cache/prek"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "*.npmjs.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "docs.claude.com",
        "api.anthropic.com",
        "*.airtable.com",
        "api.airtable.com",
        "content.airtable.com"
      ]
    }
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "bash -c 'cols=$(stty size </dev/tty 2>/dev/null | awk '\"'\"'{print $2}'\"'\"'); export COLUMNS=$(( ${cols:-120} > 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | grep -E '\"'\"'^[0-9]+\\.[0-9]+\\.[0-9]+[[:space:]]'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"{{ lookPath "bun" | replace "\\" "/" }}\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "theme": "auto"
}
'# | from json

# live ⊕ desired (desired wins; live keeps its key order and unknown keys).
# --strategy overwrite replaces arrays wholesale — the default `table` strategy
# would element-merge the hooks lists instead.
let merged = $live | merge deep --strategy overwrite ($desired | reject permissions)

# `permissions` floats: seed from desired only when the live file has none.
if ($merged | get -o permissions) == null {
  $merged | upsert permissions $desired.permissions
} else {
  $merged
} | to json --indent 2

}
