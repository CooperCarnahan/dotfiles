#!/usr/bin/env bash
# chezmoi modify_ script for ~/.claude/settings.json
#
# Claude Code owns this file: it rewrites it in its own key order and appends
# runtime keys (notif flags, session-accreted permissions) during normal use.
# A plain whole-file template fights that and makes `chezmoi diff` a wall of
# reordering noise. Instead this script receives the LIVE file on stdin and
# merges in only the "stable" keys we want chezmoi to own, preserving Claude's
# key order and its runtime-mutated keys.
#
# Floats (never touched once present): permissions.*, defaultMode,
# agentPushNotifEnabled, inputNeededNotifEnabled, and any future keys Claude adds.
# `permissions` is only seeded on a fresh machine (when the file doesn't exist).
set -euo pipefail

live="$(cat)"
[ -z "$live" ] && live='{}'

# Canonical desired config. Edit values HERE to change what chezmoi enforces.
desired="$(cat <<'DESIRED'
{
  "editorMode": "vim",
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-hud@claude-hud": true,
    "context-mode@context-mode": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "GIT_AUTHOR_EMAIL": "noreply@anthropic.com",
    "GIT_AUTHOR_NAME": "Claude",
    "GIT_COMMITTER_EMAIL": "noreply@anthropic.com",
    "GIT_COMMITTER_NAME": "Claude",
    "GIT_CONFIG_PARAMETERS": "'commit.gpgsign=false' 'tag.gpgsign=false'"
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "repo": "jarrodwatts/claude-hud",
        "source": "github"
      }
    },
    "context-mode": {
      "source": {
        "repo": "mksglu/context-mode",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ lookPath "node" }} \"{{ .chezmoi.homeDir }}/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "mcp__plugin_context-mode_context-mode__ctx_purge"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "filesystem": {
      "allowRead": [
        "~/.ssh/claude_signing",
        "~/.ssh/claude_signing.pub"
      ],
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/.cache/prek"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "*.npmjs.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "docs.claude.com",
        "api.anthropic.com",
        "*.airtable.com",
        "api.airtable.com",
        "content.airtable.com"
      ]
    }
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "bash -c 'cols=$(stty size </dev/tty 2>/dev/null | awk '\"'\"'{print $2}'\"'\"'); export COLUMNS=$(( ${cols:-120} > 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | grep -E '\"'\"'^[0-9]+\\.[0-9]+\\.[0-9]+[[:space:]]'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"{{ lookPath "bun" }}\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "theme": "auto"
}
DESIRED
)"

# jq powers the merge below. On a freshly-provisioned machine (before
# `mise install` has materialized jq) or a non-interactive apply where mise's
# shims aren't on PATH, fall back to writing the live file unchanged so apply
# never hard-fails with exit 127. The merge runs on a later apply once jq exists.
if ! command -v jq >/dev/null 2>&1; then
    printf '%s' "$live"
    exit 0
fi

# Deep-merge stable keys onto the live file (live wins on key ORDER and keeps
# any keys not in `desired`). `permissions` is excluded from the override so it
# floats; it is only seeded from `desired` when the live file has none.
jq -n --argjson live "$live" --argjson desired "$desired" '
  ($live * ($desired | del(.permissions)))
  | .permissions = (.permissions // $desired.permissions)
'
