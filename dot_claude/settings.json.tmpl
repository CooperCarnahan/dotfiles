{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ lookPath "node" }} \"{{ .chezmoi.homeDir }}/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "superpowers@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "theme": "auto",
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "{{ .chezmoi.homeDir }}/.cache/prek"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ],
      "allowRead": [
        "~/.ssh/claude_signing",
        "~/.ssh/claude_signing.pub"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "*.npmjs.org",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "*.pypi.org",
        "files.pythonhosted.org",
        "docs.claude.com",
        "api.anthropic.com",
        "*.airtable.com",
        "api.airtable.com",
        "content.airtable.com"
      ]
    }
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  }
}
