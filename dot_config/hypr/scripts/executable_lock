#!/usr/bin/env bash
# Pick the currently-active monitor and launch hyprlock on it.
#
# Lets ~/.config/hypr/hyprlock.conf stay device-agnostic (it references
# $LOCK_MONITOR), which we resolve here from live hyprctl state instead
# of hard-coding eDP-1. That way the lock UI follows whichever display
# is actually active — laptop screen when undocked, external when docked
# with the lid closed.
#
# Source of truth: ~/.config/hypr/hyprlock.conf
# Runtime config:  $XDG_RUNTIME_DIR/hyprlock-runtime.conf

set -euo pipefail

# Prefer the focused monitor; fall back to the first non-disabled one.
monitor="$(
  hyprctl -j monitors 2>/dev/null | jq -r '
    [ .[] | select(.disabled | not) ] as $enabled
    | ([ $enabled[] | select(.focused) ][0] // $enabled[0]).name // empty
  '
)"

# Ultra-fallback for the rare case hyprctl is unreachable.
: "${monitor:=eDP-1}"

runtime_config="${XDG_RUNTIME_DIR:-/tmp}/hyprlock-runtime.conf"

# Substitute only the $LOCK_MONITOR variable line in the source config.
sed -E "s|^[[:space:]]*\\\$LOCK_MONITOR[[:space:]]*=.*|\$LOCK_MONITOR = ${monitor}|" \
  "${HOME}/.config/hypr/hyprlock.conf" > "${runtime_config}"

exec hyprlock --config "${runtime_config}"
