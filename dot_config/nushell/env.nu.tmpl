# env.nu
# Installed by:
# version = "0.112.2"

$env.YAZI_CONFIG_HOME = "~/.config/yazi"
$env.EDITOR = "nvim"
$env.FZF_DEFAULT_COMMAND = "fd --type f --hidden --follow --exclude .git"
$env.FZF_DEFAULT_OPTS = '--reverse'
$env.config.edit_mode = 'vi'

# pager
$env.MANPAGER = "sh -c 'awk \"{ gsub(/\\x1B\\[[0-9;]*m/, \\\"\\\", \$0); gsub(/.\\x08/, \\\"\\\", \$0); print }\" | bat -p -lman'"

# misc. path stuff
{{- if eq .chezmoi.os "windows"}}
$env.XDG_CONFIG_HOME = $env.USERPROFILE + '/.config'
$env.ZELLIJ_CONFIG_DIR = $env.USERPROFILE + '/.config/zellij'

$env.path ++= [$env.USERPROFILE + '/.local/bin']

# rust
$env.path ++= [$env.USERPROFILE + '/.cargo/bin']

# golang
$env.path ++= [$env.USERPROFILE + '/go/bin']

{{- else }}
$env.path ++= ["~/.local/bin"]

# rust
$env.path ++= ["~/.cargo/bin"]

# golang
$env.path ++= ["~/go/bin"]
$env.path ++= ["/usr/local/go/bin"]
{{- end }}

# mise: regenerate the activation script. Actual activation (`use mise.nu`)
# happens in config.nu — doing it here would overwrite the inherited PATH
# with mise's diff (which doesn't re-list install dirs; those come back via
# mise's pre_prompt hook), breaking the `which X` checks below.
let mise_path = $nu.default-config-dir | path join mise.nu
^mise activate nu | save --force $mise_path

# Tool integrations via vendor autoload (relies on inherited PATH from
# parent shell to find mise-managed tools)
let autoload_dir = $nu.data-dir | path join "vendor/autoload"
mkdir $autoload_dir

# Tool integrations: install when binary present, clean up when absent
# so uninstalled tools don't leave orphaned files in vendor/autoload.

# television fuzzy finder
let tv_file = $autoload_dir | path join "tv.nu"
if (which tv | is-not-empty) {
  tv init nu | save --force $tv_file
} else if ($tv_file | path exists) { rm $tv_file }

# carapace completions
let carapace_file = $autoload_dir | path join "carapace.nu"
if (which carapace | is-not-empty) {
  $env.CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense'
  carapace _carapace nushell | save --force $carapace_file
} else if ($carapace_file | path exists) { rm $carapace_file }

# zoxide smart cd
let zoxide_file = $autoload_dir | path join "zoxide.nu"
if (which zoxide | is-not-empty) {
  zoxide init nushell | save --force $zoxide_file
} else if ($zoxide_file | path exists) { rm $zoxide_file }

# atuin shell history
let atuin_file = $autoload_dir | path join "atuin.nu"
if (which atuin | is-not-empty) {
  atuin init nu | save --force $atuin_file
} else if ($atuin_file | path exists) { rm $atuin_file }

# starship prompt
let starship_file = $autoload_dir | path join "starship.nu"
if (which starship | is-not-empty) {
  starship init nu | save --force $starship_file
} else if ($starship_file | path exists) { rm $starship_file }
