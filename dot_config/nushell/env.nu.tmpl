# env.nu
# Installed by:
# version = "0.114.0"

$env.YAZI_CONFIG_HOME = "~/.config/yazi"
$env.EDITOR = "nvim"
$env.config.edit_mode = 'vi'

# pager
$env.MANPAGER = "sh -c 'awk \"{ gsub(/\\x1B\\[[0-9;]*m/, \\\"\\\", \$0); gsub(/.\\x08/, \\\"\\\", \$0); print }\" | bat -p -lman'"

# misc. path stuff
{{- if eq .chezmoi.os "windows"}}
$env.XDG_CONFIG_HOME = $env.USERPROFILE + '/.config'
$env.ZELLIJ_CONFIG_DIR = $env.USERPROFILE + '/.config/zellij'

$env.path ++= [$env.USERPROFILE + '/.local/bin']

# rust
$env.path ++= [$env.USERPROFILE + '/.cargo/bin']

# golang
$env.path ++= [$env.USERPROFILE + '/go/bin']

{{- else }}
$env.path ++= ["~/.local/bin"]

# rust
$env.path ++= ["~/.cargo/bin"]

# golang
$env.path ++= ["~/go/bin"]
$env.path ++= ["/usr/local/go/bin"]
{{- end }}

$env.CLIPBOARD_NOGUI = "1"

# carapace bridges: completion fallbacks to other shells. Read at runtime by the
# carapace binary (NOT baked into its init, so not a cache input). Trimmed on
# Windows, where zsh/fish/bash aren't present and spawn slowly on every Tab.
{{- if eq .chezmoi.os "windows" }}
$env.CARAPACE_BRIDGES = ''
{{- else }}
$env.CARAPACE_BRIDGES = 'zsh,fish,bash'
{{- end }}

# Tool integrations via vendor autoload. Memoized: regenerate a tool's init only
# when nushell or the resolved binary changed (key stored as the first line),
# written atomically. Never delete on absence — keep last-good so a cold shell
# (tool not yet on PATH) still loads working integrations. Each call is guarded
# so one tool failing can't abort the rest of env.nu. Autoload sources these at
# startup only, so a regenerated init takes effect on the NEXT shell.
let autoload_dir = $nu.data-dir | path join "vendor/autoload"
mkdir $autoload_dir

def cache-file [name: string, file: path, gen: closure] {
  try {
    let found = (which $name)
    if ($found | is-empty) { return }
    let bin = ($found | get 0.path | path expand)
    # scoop shims are stable trampolines whose mtime/size never change across
    # upgrades — key on the shim's target (from the sibling .shim manifest)
    # or the cache would never invalidate (bit us with mise on Windows).
    let shim_manifest = (if ($bin | str ends-with ".exe") {
      $bin | str replace -r '\.exe$' '.shim'
    } else { "" })
    let bin = (if ($shim_manifest | path exists) {
      open $shim_manifest --raw | lines | where ($it | str starts-with "path")
        | first | split row "=" | last | str trim | str trim -c '"'
    } else { $bin })
    let st = (ls $bin | get 0)
    let tag = $"# cache-key: nu=(version | get version)|bin=($bin)|m=($st.modified)|s=($st.size)"
    let cur = (if ($file | path exists) { open $file --raw | lines | first } else { "" })
    if $cur != $tag {
      let tmp = $"($file).tmp"
      let body = (do $gen | collect)
      [$tag, $body] | str join (char nl) | save --force $tmp
      mv --force $tmp $file
    }
  } catch {|e| print $"[env.nu] cache-file ($name) failed: ($e.msg)" }
}

def cache-init [item: record<priority: int, name: string, init: list<string>>] {
  let priority = if $item.priority < 10 {
    $"0($item.priority)"
  } else {
    $"($item.priority)"
  }
  cache-file $item.name ($autoload_dir | path join $"($priority)-($item.name).nu") {||
    ^$item.name ...$item.init | collect
  }
}

# Lower numbers load earlier. Only constraint today: atuin (90) must load after
# tv (10) so atuin keeps ctrl-r (tv overrides only ctrl-r; atuin's up-arrow
# directory search is untouched). Files orphaned by a rename are pruned by the
# chezmoi run_onchange reconcile script (it matches the "# cache-key:" marker
# these files carry), so no cleanup is needed here.
let init_configs = [
  { priority: 00, name: mise,     init: [activate nu] }
  { priority: 10, name: tv,       init: [init nu] }
  { priority: 20, name: zoxide,   init: [init nushell] }
  { priority: 30, name: starship, init: [init nu] }
  { priority: 40, name: carapace, init: [_carapace nushell] }
  { priority: 90, name: atuin,    init: [init nu] }
]

for item in $init_configs {
  cache-init $item
}
