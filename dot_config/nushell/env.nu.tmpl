# env.nu
# Installed by:
# version = "0.112.2"

$env.YAZI_CONFIG_HOME = "~/.config/yazi"
$env.EDITOR = "nvim"
$env.config.edit_mode = 'vi'

# pager
$env.MANPAGER = "sh -c 'awk \"{ gsub(/\\x1B\\[[0-9;]*m/, \\\"\\\", \$0); gsub(/.\\x08/, \\\"\\\", \$0); print }\" | bat -p -lman'"

# misc. path stuff
{{- if eq .chezmoi.os "windows"}}
$env.XDG_CONFIG_HOME = $env.USERPROFILE + '/.config'
$env.ZELLIJ_CONFIG_DIR = $env.USERPROFILE + '/.config/zellij'

$env.path ++= [$env.USERPROFILE + '/.local/bin']

# rust
$env.path ++= [$env.USERPROFILE + '/.cargo/bin']

# golang
$env.path ++= [$env.USERPROFILE + '/go/bin']

{{- else }}
$env.path ++= ["~/.local/bin"]

# rust
$env.path ++= ["~/.cargo/bin"]

# golang
$env.path ++= ["~/go/bin"]
$env.path ++= ["/usr/local/go/bin"]
{{- end }}

$env.CLIPBOARD_NOGUI = "1"

# carapace bridges: completion fallbacks to other shells. Read at runtime by the
# carapace binary (NOT baked into its init, so not a cache input). Trimmed on
# Windows, where zsh/fish/bash aren't present and spawn slowly on every Tab.
{{- if eq .chezmoi.os "windows" }}
$env.CARAPACE_BRIDGES = ''
{{- else }}
$env.CARAPACE_BRIDGES = 'zsh,fish,bash'
{{- end }}

# Tool integrations via vendor autoload. Memoized: regenerate a tool's init only
# when nushell or the resolved binary changed (key stored as the first line),
# written atomically. Never delete on absence — keep last-good so a cold shell
# (tool not yet on PATH) still loads working integrations. Each call is guarded
# so one tool failing can't abort the rest of env.nu. Autoload sources these at
# startup only, so a regenerated init takes effect on the NEXT shell.
let autoload_dir = $nu.data-dir | path join "vendor/autoload"
mkdir $autoload_dir

def cache-init [name: string, file: path, gen: closure] {
  try {
    let found = (which $name)
    if ($found | is-empty) { return }
    let bin = ($found | get 0.path | path expand)
    let st = (ls $bin | get 0)
    let tag = $"# cache-key: nu=(version | get version)|bin=($bin)|m=($st.modified)|s=($st.size)"
    let cur = (if ($file | path exists) { open $file --raw | lines | first } else { "" })
    if $cur != $tag {
      let tmp = $"($file).tmp"
      [$tag, (do $gen)] | str join (char nl) | save --force $tmp
      mv --force $tmp $file
    }
  } catch {|e| print $"[env.nu] cache-init ($name) failed: ($e.msg)" }
}

# mise: regenerate the activation script only when nu or the mise binary
# changed (memoized via cache-init — this was the last unconditional
# subprocess on every startup). Actual activation (`use mise.nu`) happens in
# config.nu — doing it here would overwrite the inherited PATH with mise's
# diff (which doesn't re-list install dirs; those come back via mise's
# pre_prompt hook), breaking cache-init's `which X` checks. cache-init writes
# nothing when mise is absent, so stub mise.nu in that case: config.nu's
# parse-time `use mise.nu` must never brick startup. The `# cache-key:` first
# line is a plain nu comment, harmless to `use`.
let mise_path = $nu.default-config-dir | path join mise.nu
cache-init mise $mise_path {|| ^mise activate nu }
if not ($mise_path | path exists) { "# mise unavailable (stub)\n" | save --force $mise_path }

# Numeric prefixes make autoload order explicit. Only constraint today: atuin
# (90) must load after tv (10) so atuin keeps ctrl-r (tv overrides only ctrl-r;
# atuin's up-arrow directory search is untouched). Files orphaned by a rename
# are pruned by the chezmoi run_onchange reconcile script (it matches the
# "# cache-key:" marker these files carry), so no cleanup is needed here.
cache-init tv       ($autoload_dir | path join "10-tv.nu")       {|| tv init nu }
cache-init zoxide   ($autoload_dir | path join "20-zoxide.nu")   {|| zoxide init nushell }
cache-init starship ($autoload_dir | path join "30-starship.nu") {|| starship init nu }
cache-init carapace ($autoload_dir | path join "40-carapace.nu") {|| carapace _carapace nushell }
cache-init atuin    ($autoload_dir | path join "90-atuin.nu")    {|| atuin init nu }
