# config.nu
#
# Installed by:
# version = "0.112.2"

# fzf launchers. Start permissive (hidden + gitignored shown); ctrl-h toggles
# to a clean view and back. State is encoded in the prompt: "all> " vs "> ".
# POSIX `[ ]` used in the bind so it works regardless of $SHELL.
def fzf-pick-file [] {
  fd --hidden --no-ignore
    | fzf --height=40% --prompt 'all> ' --preview 'bat -n --color=always {}' --header 'ctrl-h: toggle hidden/ignored' --bind 'ctrl-h:transform:[ "$FZF_PROMPT" = "all> " ] && echo "reload(fd)+change-prompt(> )" || echo "reload(fd --hidden --no-ignore)+change-prompt(all> )"'
}

def fzf-pick-dir [] {
  fd --type dir --hidden --no-ignore
    | fzf --height=40% --prompt 'all> ' --header 'ctrl-h: toggle hidden/ignored' --bind 'ctrl-h:transform:[ "$FZF_PROMPT" = "all> " ] && echo "reload(fd --type dir)+change-prompt(> )" || echo "reload(fd --type dir --hidden --no-ignore)+change-prompt(all> )"'
}

$env.config.keybindings ++= [
  {
    name: fzf_paste
    modifier: control
    keycode: char_t
    mode: vi_normal
    event: {
        send: executehostcommand,
        cmd: "commandline edit --insert (fzf-pick-file | str trim)"
      }
  },
  {
    name: nvim_fzf
    modifier: control
    keycode: char_v
    mode: [vi_normal, vi_insert]
    event: {
        send: executehostcommand,
        cmd: "nvim (fzf-pick-file)"
      }
  }
  {
    name: cd_fzf
    modifier: control
    keycode: char_d
    mode: [vi_normal, vi_insert]
    event: {
        send: executehostcommand,
        cmd: "cd (fzf-pick-dir)"
      }
  }
]

def --env yz [...args] {
	let tmp = (mktemp -t "yazi-cwd.XXXXXX")
	yazi ...$args --cwd-file $tmp
	let cwd = (open $tmp)
	if $cwd != "" and $cwd != $env.PWD {
		cd $cwd
	}
	rm -fp $tmp
}

{{- if not (eq .chezmoi.os "windows") }}
alias fg = job unfreeze
{{- end }}
alias v = nvim
alias cat = bat
alias mr = mise run
alias nv = neovide
alias cha = chezmoi add
alias chd = chezmoi diff
alias che = nvim ~/.local/share/chezmoi
alias chlg = lazygit -p ~/.local/share/chezmoi/
alias zj = zellij
alias rgi = rg -uu
alias fdi = fd -IH
alias cc = cd -
alias zz = cd -
alias zp = cd -

def zja [] {
    zellij attach (zellij list-sessions | ansi strip | fzf)
}

alias .. = cd ..
alias ... = cd ../..
alias .... = cd ../../..
alias ..... = cd ../../../..
alias ...... = cd ../../../../..

alias lg = lazygit
alias gsur = git submodule update --init --recursive -j 12
alias gbsc = git branch --show-current
alias grh = git reset --hard
alias grb = git rebase
alias grho = git reset --hard origin/(git branch --show-current)
alias gc = git commit
alias gl = git pull
alias gp = git push
alias gco = git checkout
alias gst = git status

# mise (activation must run after env.nu so the pre_prompt hook is set up
# in the same scope as the prompt)
use ($nu.default-config-dir | path join mise.nu)
