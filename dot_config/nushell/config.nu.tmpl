# config.nu
#
# Installed by:
# version = "0.112.2"

# Picker keybindings, backed by tv channels. ctrl-t is tv's own smart
# autocomplete (from its autoload integration); ctrl-r is atuin. Each binding
# is guarded so escaping the picker (empty selection) is a no-op, not an error.
$env.config.keybindings ++= [
  {
    name: nvim_tv
    modifier: control
    keycode: char_v
    mode: [vi_normal, vi_insert]
    event: { send: executehostcommand, cmd: "let f = (tv files | str trim); if ($f | is-not-empty) { nvim $f }" }
  }
  {
    name: cd_tv
    modifier: control
    keycode: char_d
    mode: [vi_normal, vi_insert]
    event: { send: executehostcommand, cmd: "let d = (tv dirs | str trim); if ($d | is-not-empty) { cd $d }" }
  }
  {
    name: zoxide_tv
    modifier: control
    keycode: char_z
    mode: [vi_normal, vi_insert]
    event: { send: executehostcommand, cmd: "let d = (tv zoxide | str trim); if ($d | is-not-empty) { cd $d }" }
  }
]

def --env yz [...args] {
	let tmp = (mktemp -t "yazi-cwd.XXXXXX")
	yazi ...$args --cwd-file $tmp
	let cwd = (open $tmp)
	if $cwd != "" and $cwd != $env.PWD {
		cd $cwd
	}
	rm -fp $tmp
}

