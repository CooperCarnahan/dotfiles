-- Generated by hyprdynamicmonitors. Edit this template, not the rendered output.
-- The laptop display is matched by kernel name (eDP-1) in config.toml,
-- so this template is portable across machines without changes.
{{- $laptop := index .MonitorsByTag "laptop" }}
-- <<<<< TUI AUTO START
hl.monitor({ output = "desc:{{ $laptop.Description }}", mode = "2880x1800@120.00000", position = "1760x1520", scale = "1.50000000", transform = 0, vrr = 0 })
-- <<<<< TUI AUTO END
