urls:
{{- if eq .chezmoi.os "darwin" }}
  - macosx://:
      tag: desk
{{- else if eq .chezmoi.os "windows" }}
  - windows://:
      tag: desk
{{- else }}
  - gnome://:
      tag: desk
{{- end }}
{{- if .work }}
  # pover://YOUR_USER_KEY@YOUR_API_TOKEN:
  #     tag: phone
{{- else if (lookPath "op") }}
{{-   $pushover := onepasswordDetailsFields "Pushover API Credentials" }}
  - pover://{{ $pushover.username.value }}@{{ $pushover.credential.value }}:
      tag: phone
{{- else }}
  # 1Password CLI ('op') not found. Run 'chezmoi apply' again after installing and signing into 1Password.
{{- end }}
