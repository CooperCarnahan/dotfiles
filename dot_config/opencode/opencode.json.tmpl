{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "debugmcp": {
      "type": "remote",
      "url": "http://localhost:3001/mcp"
    },
    "codegraph": {
      "type": "local",
      "command": [
        "bunx",
        "@colbymchenry/codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
  },
  "agent": {
{{- if .work }}
    "explore": {
      "model": "github-copilot/gpt-5-mini",
    },
    "general": {
      "model": "github-copilot/gpt-5-mini",
    },
{{- end }}
    "plan": {
      "permission": {
        "webfetch": "allow",
        "bash": "allow",
        "edit": "deny",
      },
    },
  },
  "plugin": [
{{- if not .work }}
    "opencode-gemini-auth@latest",
    "./plugins/notify-tool.ts",
{{- end }}
    "./plugins/rtk.ts",
    "opencode-beads",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "context-mode"
  ],
  "permission": {
{{- if .work -}}
    "gh_grep": "deny",
{{- end -}}
  },
}
