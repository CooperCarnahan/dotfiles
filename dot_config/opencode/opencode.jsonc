{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "npx",
        "gitnexus",
        "mcp"
      ],
    },
    // "context7": {
    //   "type": "remote",
    //   "url": "https://mcp.context7.com/mcp",
    // },
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5-mini",
    },
    "general": {
      "model": "github-copilot/gpt-5-mini",
    },
    "plan": {
      "permission": {
        "webfetch": "allow",
        "bash": "allow",
        "edit": "deny",
      },
    },
  },
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-beads",
    "./plugins/notify-tool.ts",
    "superpowers@git+https://github.com/obra/superpowers.git",
  ],
  "permission": {
    "gh_grep": "deny",
    "context7": "deny",
  },
}
