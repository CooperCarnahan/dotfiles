{
  // -------------------------------------------------------------------------
  // Global configuration
  // -------------------------------------------------------------------------
  "layer": "top",
  "position": "top",
  //"height": 20,
  "margin-left": 10,
  "margin-bottom": 0,
  "margin-right": 10,
  "spacing": 5, // Gaps between modules (4px)
  "modules-left": [
    //"custom/rofi",
    "hyprland/workspaces",
    //"hyprland/submap",
    "temperature",
    //"idle_inhibitor",
    //"mpd"
    "mpris"
  ],
  "modules-center": [
    //"hyprland/window"
    "clock#date",
    "custom/weather"
    //"custom/gammastep"
  ],
  "modules-right": [
    "custom/storage",
    "memory",
    "network",
    "battery",
    //"pulseaudio",
    "backlight",
    "wireplumber",
    "custom/screenshot_t",
    "custom/notification",
    "tray",
    "custom/power"
  ],
  // -------------------------------------------------------------------------
  // Modules
  // -------------------------------------------------------------------------
  "custom/sp1": {
    "format": " | ",
    "tooltip": false
  },
  "custom/sp2": {
    "format": " |",
    "tooltip": false
  },
  "custom/rofi": {
    "format": "ΎΔΚ",
    "tooltip": false,
    "on-click-right": "nwg-drawer",
    "on-click": "wofi --show run",
    "on-click-middle": "pkill -9 wofi"
  },
  "custom/screenshot_t": {
    "format": " ΎΑ░ ",
    "on-click": "hyprshot -m output --clipboard-only",
    "on-click-right": "hyprshot -m region --clipboard-only"
  },
  "clock#1": {
    "format": "ΎΒ│ {:%a}",
    "tooltip": false,
    "on-click": "gsimplecal"
  },
  "clock#2": {
    "format": "ΎΚ┤ {:%d-%h-%Y}",
    "tooltip": false,
    "on-click": "gsimplecal"
  },
  "clock#3": {
    "format": "ΎΑΩ {:%H:%M:%S %p}",
    "tooltip": false,
    "on-click": "gsimplecal"
  },
  "temperature": {
    // "thermal-zone": 1,
    "interval": 4,
    //"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "ΎΜΚ {temperatureC}┬░C",
    "format-critical": "ΎΒ▒  {temperatureC}┬░C",
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": [
      "ΎΜΜ",
      "ΎΜΚ",
      "ΎΜΘ"
    ],
    "max-length": 7,
    "min-length": 7,
    "on-click": "xsensors"
  },
  "memory": {
    "interval": 30,
    "format": "ΎΜδ  {used:0.2f} / {total:0.0f} GB",
    "on-click": "alacritty -e btop"
  },
  "battery": {
    "interval": 2,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤▒Λξ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "network": {
    "format-wifi": "ΎΘτ  {essid}",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} Ό╜Ε ",
    "format-linked": "{ifname} (No IP) Ό╜Ε ",
    "format": "ΎΑΤ ",
    "format-disconnected": "≤░νχ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
    "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
    "tooltip-format": "ΎΓΥ {bandwidthUpBits} ΎΑβ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
    "tooltip-format-wifi": "ΎΘτ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nΎΓΥ {bandwidthUpBits} ΎΑβ {bandwidthDownBits}",
    "interval": 10
  },
  "custom/storage": {
    "format": "≤░ΜΛ {}",
    "return-type": "json",
    "interval": 60,
    "exec": "~/.config/waybar/modules/storage.sh"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "≤░Δη ",
      "≤░Δθ ",
      "≤░Δι "
    ],
    "on-scroll-down": "brightnessctl s 5%-",
    "on-scroll-up": "brightnessctl s +5%"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    },
    "tooltip": "true"
  },
  "custom/weather": {
    "format": "{}",
    "interval": 3600,
    "exec": "curl -s 'https://wttr.in/?u&format=1'",
    //"return-type": "json",
    //"exec": "~/.config/waybar/modules/weather.sh",
    "exec-if": "ping wttr.in -c1"
  },
  "custom/pacman": {
    "format": "<big>ΪΠΗ▓</big>  {}",
    "interval": 3600, // every hour
    "exec": "checkupdates | wc -l", // # of updates
    "exec-if": "exit 0", // always run; consider advanced run conditions
    "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
    "signal": 8,
    "max-length": 5,
    "min-length": 3
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "format-stopped": "",
    "player-icons": {
      "default": "",
      "spotify": "",
      "spotify_player": ""
    },
    "status-icons": {
      "paused": "",
      "playing": "",
      "stopped": ""
    },
    "dynamic-order": ["title", "artist"],
    "dynamic-separator": " ┬╖ ",
    "dynamic-len": 50,
    "interval": 1,
    "tooltip-format": "{status} on {player}\n{title}\n{artist}\n{album}",
    "on-click": "playerctl --player=spotify_player,spotify play-pause",
    "on-click-right": "~/.local/bin/sink-switcher",
    "on-click-middle": "~/.local/bin/spotify-tui-toggle",
    "on-scroll-up": "playerctl --player=spotify_player,spotify next",
    "on-scroll-down": "playerctl --player=spotify_player,spotify previous"
  },
  "custom/media": {
    "format": "{0} {1}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "ΎΗ╝",
      "default": "ΏθΟε"
    },
    "escape": true
    //"exec": "~/.config/waybar/mediaplayer.py" // Script in resources folder
    // "exec": "~/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
  },
  "custom/power": {
    "format": " ≤░Ρξ ",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "clock": {
    "format": "ΎΑΩ  {:%I:%M %p ΎΒ│ %e %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "today-format": "<b>{}</b>"
  },
  "clock#date": {
    "format": "≤░ξΦ  {:%I:%M %p \nΎΒ│ %e %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "today-format": "<b>{}</b>"
  },
  "custom/gammastep": {
    "interval": 5,
    "return-type": "json",
    "exec": {
      "pre": "if unit_status=\"$(systemctl --user is-active gammastep)\"; then\nstatus=\"$unit_status ($(journalctl --user -u gammastep.service -g 'Period: ' | tail -1 | cut -d ':' -f6 | xargs))\"\nelse\nstatus=\"$unit_status\"\nfi",
      "alt": "${status:-inactive}",
      "tooltip": "Gammastep is $status"
    },
    "format": "{icon}",
    "format-icons": {
      "activating": "≤░Βς ",
      "deactivating": "≤░Βς ",
      "inactive": "? ",
      "active (Night)": "ΎΗΗ ",
      "active (Nighttime)": "ΎΗΗ ",
      "active (Transition (Night)": "ΎΗΗ ",
      "active (Transition (Nighttime)": "ΎΗΗ ",
      "active (Day)": "ΌΝΞ ",
      "active (Daytime)": "ΌΝΞ ",
      "active (Transition (Day)": "ΌΝΞ ",
      "active (Transition (Daytime)": "ΌΝΞ ",
    },
    "on-click": "systemctl --user is-active gammastep && systemctl --user stop gammastep || systemctl --user start gammastep",
  },
  "cpu": {
    "interval": 1,
    //"format": " {}%", // Icon: microchip
    "format": "{max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
    "max-length": 13,
    "min-length": 13,
    "on-click": "ghostty -e btop"
  },
  "mpd": {
    "max-length": 25,
    "format": "<span foreground='#bb9af7'>ΎΑΒ</span> {title}",
    "format-paused": "ΎΑΒ {title}",
    "format-stopped": "<span foreground='#bb9af7'>ΎΑΒ</span>",
    "format-disconnected": "",
    "on-click": "mpc --quiet toggle",
    "on-click-right": "mpc update; mpc ls | mpc add",
    "on-click-middle": "alacritty -e ncmpcpp",
    "on-scroll-up": "mpc --quiet prev",
    "on-scroll-down": "mpc --quiet next",
    "smooth-scrolling-threshold": 5,
    "tooltip-format": "{title} - {artist} ({elapsedTime:%M:%S}/{totalTime:%H:%M:%S})"
  },
  "custom/title": {
    "format": "{}",
    "interval": 0,
    "return-type": "json",
    //"max-length": 35,
    "tooltip": false
  },
  "custom/title#name": {
    "format": "{}",
    "interval": 0,
    "return-type": "json",
    "max-length": 35,
    "exec": "$HOME/.scripts/title"
  },
  /*"custom/keyboard": {
        "format": "ΎΕε {}",
        "interval": 1,
        "exec": "$HOME/.config/waybar/get_kbdlayout.sh"
    },*/
  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "1": "ΌηΧ",
      "2": "≤░Ψθ",
      "3": "3",
      "4": "4",
      "5": "5",
      "6": "6",
      "7": "7",
      "8": "8",
      "9": "9",
      "10": "10",
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
    "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
    "sort-by-number": true,
    "active-only": false,
  },
  "hyprland/window": {
    "max-length": 100,
    "separate-outputs": true
  },
  "pulseaudio": {
    "scroll-step": 3, // %, can be a float
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Όυν {icon}ΎΛΦ {format_source}",
    "format-muted": "Όυν {format_source}",
    //"format-source": "{volume}% ΎΕ░",
    //"format-source-muted": "ΎΕ▒",
    "format-source": "ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle"
  },
  "wireplumber": {
    // "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle 1>/dev/null",
    "on-click": "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle",
    // "on-scroll-down": "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-",
    // "on-scroll-up": "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+",
    "format": "<span foreground='#fab387'>{icon}</span>  {volume}%",
    "format-source": "ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-muted": "<span foreground='#fab387'>ΎΣο </span>",
    //"format-icons": [ "<span foreground='#fab387'>ΎΑρ</span>" ]
    "format-icons": {
      "headphone": "ΎΑξ ",
      "hands-free": "ΎΨΡ ",
      "headset": "ΎΨΡ ",
      "phone": "ΎΓΧ ",
      "portable": "ΎΓΧ ",
      "car": "ΎΗ╣ ",
      "default": [
        "ΎΑο ",
        "ΎΑπ ",
        "ΎΑρ "
      ]
    },
  },
  "tray": {
    "icon-size": 15,
    "spacing": 5
  },
  "custom/notification": {
    "tooltip": false,
    "format": " {icon} ",
    "format-icons": {
      "notification":               "<span foreground='#e06c75'>≤░╡β</span>",
      "none":                       "≤░Γγ",
      "dnd-notification":           "<span foreground='#e06c75'>≤░Γδ</span>",
      "dnd-none":                   "≤░Γδ",
      "inhibited-notification":     "<span foreground='#e06c75'>≤░╡β</span>",
      "inhibited-none":             "≤░Γγ",
      "dnd-inhibited-notification": "<span foreground='#e06c75'>≤░Γδ</span>",
      "dnd-inhibited-none":         "≤░Γδ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
