    "on-click": "xsensors"
  },
  "memory": {
    "interval": 30,
    "format": "´ïø  {used:0.2f} / {total:0.0f} GB",
    "on-click": "alacritty -e btop"
  },
  "battery": {
    "interval": 2,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¾▒èÑ {capacity}%",
    "format-plugged": "´çĞ {capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ]
  },
  "network": {
    "format-wifi": "´ç½  {essid}",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} ¯¢ä ",
    "format-linked": "{ifname} (No IP) ¯¢ä ",
    "format": "´ÇÆ ",
    "format-disconnected": "¾░ñ« ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
    "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
    "tooltip-format": "´éô {bandwidthUpBits} ´ÇÖ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
    "tooltip-format-wifi": "´ç½ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\n´éô {bandwidthUpBits} ´ÇÖ {bandwidthDownBits}",
    "interval": 10
  },
  "custom/storage": {
    "format": "¾░ïè {}",
    "return-type": "json",
    "interval": 60,
    "exec": "~/.config/waybar/modules/storage.sh"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "¾░âŞ ",
      "¾░âş ",
      "¾░âá "
    ],
    "on-scroll-down": "brightnessctl s 5%-",
