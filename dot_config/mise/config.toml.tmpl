difftastic = "latest"
eza = "latest"
fastfetch = "latest"
fd = "latest"
fzf = "latest"
gh = "latest"
"github:can1357/oh-my-pi" = "latest"
"github:rtk-ai/rtk" = "latest"
go = "latest"
