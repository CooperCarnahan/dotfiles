{{- if eq .chezmoi.os "linux" -}}
{{- if or (eq .osid "linux-arch") (eq .osid "linux-cachyos") -}}
#!/usr/bin/env bash
# Configure greetd + tuigreet as the active display manager.
# Re-runs whenever the embedded config below changes.
#
# config-version: 1

set -euo pipefail

# Bail until the package installer has put greetd in place.
if ! command -v greetd >/dev/null 2>&1; then
    echo "skipping greetd setup: greetd not installed yet (rerun chezmoi apply after install_arch_packages)"
    exit 0
fi

CONFIG=/etc/greetd/config.toml
NEW=$(mktemp)
trap 'rm -f "$NEW"' EXIT

cat > "$NEW" <<'TOML'
[terminal]
vt = 1

[default_session]
command = "tuigreet --time --remember --remember-user-session --asterisks --sessions /usr/share/wayland-sessions"
user = "greeter"
TOML

if ! sudo test -f "$CONFIG" || ! sudo cmp -s "$NEW" "$CONFIG"; then
    echo "writing $CONFIG"
    sudo install -d -m 755 /etc/greetd
    sudo install -m 644 "$NEW" "$CONFIG"
fi

# Disable any competing display managers FIRST so the display-manager.service
# symlink they own is freed before we enable greetd. Only act on units that
# are installed and currently enabled — leaves minimal systems alone.
for dm in gdm sddm lightdm lxdm; do
    if systemctl list-unit-files "${dm}.service" >/dev/null 2>&1 \
        && systemctl is-enabled "${dm}.service" >/dev/null 2>&1; then
        echo "disabling ${dm}.service"
        sudo systemctl disable "${dm}.service" >/dev/null
    fi
done

# Enable greetd at boot. Idempotent.
sudo systemctl enable greetd.service >/dev/null
{{- end -}}
{{- end -}}
