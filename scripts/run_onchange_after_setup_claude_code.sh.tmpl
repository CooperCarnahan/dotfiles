{{- if eq .chezmoi.os "linux" -}}
{{- if or (eq .osid "linux-arch") (eq .osid "linux-cachyos") -}}
#!/usr/bin/env bash
# Post-install setup for Claude Code:
#   - Register plugin marketplaces (so `claude plugin install` can find plugins)
#   - Install the user's regularly-used plugins
#   - Register MCP servers
#
# Runs `after` package install so the `claude` CLI is on PATH (provisioned via
# mise from run_onchange_install_arch_packages.sh.tmpl). Idempotent — every
# step swallows "already exists" errors via `|| true`. chezmoi re-runs this
# script whenever its content changes (run_onchange_ hash).

set -uo pipefail

# Bail out gracefully on systems without claude on PATH yet.
if ! command -v claude >/dev/null 2>&1; then
    echo "claude CLI not found on PATH — skipping Claude Code post-install setup"
    exit 0
fi

echo "--- Adding Claude Code plugin marketplaces ---"
marketplaces=(
    jarrodwatts/claude-hud
    mksglu/context-mode
    forrestchang/andrej-karpathy-skills
    anthropics/claude-plugins-official
)
for src in "${marketplaces[@]}"; do
    claude plugin marketplace add "${src}" 2>/dev/null || true
done

echo "--- Installing Claude Code plugins ---"
plugins=(
    claude-hud@claude-hud
    context-mode@context-mode
    andrej-karpathy-skills@karpathy-skills
    lua-lsp@claude-plugins-official
)
for plugin in "${plugins[@]}"; do
    claude plugin install --scope user "${plugin}" 2>/dev/null || true
done

echo "--- Registering Claude Code MCP servers ---"
# debugmcp: local HTTP debugger MCP at localhost:3001. The `|| true` covers
# the "server already exists" case since `claude mcp add` errors in that path.
if ! claude mcp list 2>/dev/null | grep -q "^debugmcp:"; then
    claude mcp add --transport http --scope user debugmcp http://localhost:3001/mcp 2>&1 || true
fi

echo "--- Claude Code setup complete ---"
{{- end -}}
{{- end -}}
