{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}
{{- $work := false -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $work = promptBoolOnce . "work" "Is this a work machine?" -}}
{{- end -}}
{{- /* Desktop vs headless — a Linux-only concept (Windows/macOS boxes always have
       a desktop, so don't even prompt there). Default: headless on any Linux that
       isn't Arch/CachyOS (those are the desktop boxes). Drives .chezmoiignore +
       desktop packages. */ -}}
{{- $headless := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $headlessDefault := false -}}
{{-   if hasKey .chezmoi.osRelease "id" -}}
{{-     $headlessDefault = not (or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos")) -}}
{{-   end -}}
{{-   $headless = promptBoolOnce . "headless" "Is this a headless machine (no desktop / Wayland session)?" $headlessDefault -}}
{{- end -}}
{{- $pushoverUrl := "" -}}
{{- if and (not $work) (lookPath "op") -}}
{{-   $pushover := onepasswordDetailsFields "Pushover API Credentials" -}}
{{-   $pushoverUrl = printf "pover://%s@%s" $pushover.username.value $pushover.credential.value -}}
{{- end -}}

[data]
    osid = {{ $osid | quote }}
    work = {{ $work }}
    headless = {{ $headless }}
    pushoverUrl = {{ $pushoverUrl | quote }}

[interpreters.ps1]
    command = "powershell"
    args = ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]

# Run .nu chezmoi scripts (Windows can't exec a shebang; on Unix this makes the
# target name resolve identically — chezmoi strips a matching interpreter
# extension, e.g. modify_settings.json.nu -> settings.json). --stdin wires the
# live file into $in for modify_ scripts; harmless for run_ scripts.
[interpreters.nu]
    command = "nu"
    args = ["--stdin"]

[diff]
    command = "difft"
    args = [
        "--color", "always",
        "--skip-unchanged",
        "{{ `{{ .Destination }}` }}",
        "{{ `{{ .Target }}` }}"
    ]
    pager = "less -R"

[merge]
    command = "nvim"
    args = [
        "-d",
        "{{ `{{ .Destination }}` }}",
        "{{ `{{ .Source }}` }}",
        "{{ `{{ .Target }}` }}"
    ]
